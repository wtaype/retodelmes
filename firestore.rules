rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── FUNCIONES DE AYUDA (Compacto & Semántico) ─────────────────────────────
    function conAuth()    { return request.auth != null; }
    function esDueno(r)   { return conAuth() && r.data.uid == request.auth.uid; }
    
    // Obtener rol del documento del usuario usando su token.name (displayName)
    function getRol()     { return get(/databases/$(database)/documents/smiles/$(request.auth.token.name)).data.rol; }
    function esAdmin()    { return conAuth() && getRol() == 'admin'; }
    function esGestor()   { return conAuth() && getRol() in ['gestor', 'admin']; }
    function esEditor()   { return conAuth() && getRol() in ['editor', 'gestor', 'admin']; }

    // ── COLECCIONES CON CONAUTH (Accesos Consolidados en una Línea) ───────────
    match /registrosdb/{d}  { allow read, write: if conAuth(); }
    match /listatours/{d}   { allow read, write: if conAuth(); }
    match /chatSmiles/{d}   { allow read, write: if conAuth(); }
    match /ganadores/{d}    { allow read, write: if conAuth(); }
    
    // ── AVISOS DE EQUIPO (NOTAS) ─────────────────────────────────────────────
    // Cualquier usuario logueado lee, pero solo gestores/admins pueden escribir notas
    match /notas/{d}        { allow read: if conAuth(); allow write: if esGestor(); }
    
    // ── COLECCIÓN SMILES (USUARIOS) ──────────────────────────────────────────
    match /smiles/{usuario} {
      // get público para login.js fetchUser (búsqueda inicial por email/username sin Auth)
      allow read: if true;
      // Solo gestores logueados crean (vía trabajador_nuevo.js)
      allow create: if esGestor() && request.resource.data.rol != 'admin';
      // Dueños y gestores/admins pueden actualizar perfiles, impidiendo que se auto-asciendan a admin
      allow update: if (esDueno(resource) || esGestor()) && (request.resource.data.rol != 'admin' || resource.data.rol == 'admin');
      // Eliminación: restringido únicamente a administradores
      allow delete: if esAdmin();
    }

    // ── CONFIGWII (Bóveda TOTP) ───────────────────────────────────────────────
    // Restringido exclusivamente a administradores para control de seguridad TOTP
    match /configwii/{usuario} {
      allow read, write: if esAdmin();
    }


  }
}